# ============================================
# PayOps360 MVP - Root .gitignore
# ============================================

# ============================================
# BACKEND (Java/Maven)
# ============================================

# Maven
target/
!.mvn/wrapper/maven-wrapper.jar
!**/src/main/**/target/
!**/src/test/**/target/

# STS
.apt_generated
.classpath
.factorypath
.project
.settings
.springBeans
.sts4-cache

# IntelliJ IDEA
.idea
*.iws
*.iml
*.ipr

# NetBeans
/nbproject/private/
/nbbuild/
/dist/
/nbdist/
/.nb-gradle/
build/
!**/src/main/**/build/
!**/src/test/**/build/

# VS Code
.vscode/

# Mac
.DS_Store

# Windows
Thumbs.db
desktop.ini

# Logs
*.log
logs/

# Temp files
*.tmp
*.bak
*.swp
*~

# Package Files
*.jar
*.war
*.nar
*.ear
*.zip
*.tar.gz
*.rar

# Database
*.db
*.sqlite

# Application properties with sensitive data
application-local.yml

# ============================================
# FRONTEND (Next.js/Node)
# ============================================

# Dependencies
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Next.js
.next/
out/

# Production build
/build

# Environment Variables
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
!.env.example

# Testing
coverage/
*.lcov
.nyc_output

# Turbopack & Misc
.turbo
.vercel

# ============================================
# DOCUMENTATION
# ============================================

# Documentation temp files
docs/.~*
docs/*~
docs/*.bak
.directory

# ============================================
# GENERAL
# ============================================

# System Files
.Trashes
Thumbs.db
.DS_Store

# Editor temp files
*~.nib
*.swp
*.swo

